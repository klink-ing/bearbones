{
  "name": "@klinking/panda-shorthand",
  "version": "0.0.0",
  "description": "Panda CSS plugin that lowers Tailwind-flavored utility strings (e.g. `css('p-4')`) into Panda's native object form at extraction + dev-server time.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@babel/parser": "catalog:",
    "magic-string": "catalog:"
  },
  "devDependencies": {
    "@klinking/panda-utils": "workspace:*",
    "@pandacss/dev": "catalog:",
    "@pandacss/types": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@pandacss/dev": "*"
  }
}
